generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  name               String
  password           String
  role               Role              @default(BUYER)
  phone              String?
  stripeCustomerId   String?
  stripeAccountId    String?
  verified           Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  totpSecret         String?
  bids               Bid[]
  checkoutSessions   CheckoutSession[]
  listings           Listing[]
  buyerTransactions  Transaction[]     @relation("BuyerTransactions")
  sellerTransactions Transaction[]     @relation("SellerTransactions")

  @@map("users")
}

model Team {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  sport  String
  city   String  @default("Miami")
  active Boolean @default(true)
  games  Game[]

  @@map("teams")
}

model Game {
  id         String     @id @default(cuid())
  teamId     String
  homeTeam   String
  awayTeam   String
  venue      String
  gameTime   DateTime
  season     String
  status     GameStatus @default(UPCOMING)
  externalId String?    @unique
  team       Team       @relation(fields: [teamId], references: [id])
  listings   Listing[]

  @@index([gameTime])
  @@index([teamId, gameTime])
  @@map("games")
}

model Listing {
  id                      String           @id @default(cuid())
  sellerId                String
  gameId                  String
  section                 String
  row                     String
  seatNumbers             String
  quantity                Int
  askingPrice             Float
  description             String?
  liveTriggerType         LiveTriggerType  @default(T_60)
  status                  TicketStatus       @default(DRAFT)
  verificationStatus      VerificationStatus @default(PENDING)
  verificationNote        String?
  activeCheckoutSessionId String?            @unique
  activatedAt             DateTime?
  closedAt                DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  barcodeNumber           String?
  custodyEmail            String?
  custodyTransferredAt    DateTime?
  expiryJobId             String?
  mlbTransferLink         String?
  notificationJobId       String?
  notificationSentAt      DateTime?
  bids                    Bid[]
  activeCheckoutSession   CheckoutSession? @relation(fields: [activeCheckoutSessionId], references: [id])
  game                    Game             @relation(fields: [gameId], references: [id])
  seller                  User             @relation(fields: [sellerId], references: [id])
  transaction             Transaction?

  @@index([gameId, status])
  @@index([sellerId, status])
  @@index([status, liveTriggerType])
  @@map("listings")
}

model CheckoutSession {
  id                    String    @id @default(cuid())
  buyerId               String
  stripePaymentIntentId String?
  expiresAt             DateTime
  completedAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime  @default(now())
  buyer                 User      @relation(fields: [buyerId], references: [id])
  listing               Listing?

  @@index([buyerId])
  @@index([expiresAt])
  @@map("checkout_sessions")
}

model Bid {
  id          String       @id @default(cuid())
  listingId   String
  bidderId    String
  amount      Float
  status      BidStatus    @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bidder      User         @relation(fields: [bidderId], references: [id])
  listing     Listing      @relation(fields: [listingId], references: [id])
  transaction Transaction?

  @@index([listingId])
  @@index([bidderId])
  @@map("bids")
}

model Transaction {
  id                    String            @id @default(cuid())
  listingId             String            @unique
  bidId                 String?           @unique
  buyerId               String
  sellerId              String
  salePrice             Float
  commissionRate        Float             @default(0.15)
  commissionAmount      Float
  sellerPayout          Float
  stripePaymentIntentId String?
  stripeTransferId      String?
  status                TransactionStatus @default(PENDING)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  bid                   Bid?              @relation(fields: [bidId], references: [id])
  buyer                 User              @relation("BuyerTransactions", fields: [buyerId], references: [id])
  listing               Listing           @relation(fields: [listingId], references: [id])
  seller                User              @relation("SellerTransactions", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@map("transactions")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum GameStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
}

enum LiveTriggerType {
  T_60
  T_30
  POST_START
}

enum TicketStatus {
  DRAFT
  LIVE
  SOLD
  EXPIRED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}
