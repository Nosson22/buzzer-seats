{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "noEmit": false,
    "target": "ES2020"
  },
  "include": [
    "server.ts",
    "lib/**/*",
    "services/**/*",
    "prisma/seed.ts"
  ],
  "exclude": [
    "node_modules",
    "app/**/*",
    "components/**/*"
  ]
}
