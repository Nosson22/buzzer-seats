{
  "name": "marlins-tickets",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "ts-node --project tsconfig.server.json worker.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "dev:server": "ts-node --project tsconfig.server.json server.ts",
    "dev:worker": "ts-node --project tsconfig.server.json lib/queue/activation.worker.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:worker\""
  },
  "dependencies": {
    "@aws-sdk/client-device-farm": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@hookform/resolvers": "^3.9.0",
    "@playwright/browser-chromium": "^1.61.1",
    "@prisma/client": "^6.0.0",
    "@stripe/react-stripe-js": "^3.1.0",
    "@stripe/stripe-js": "^5.5.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "^15.5.19",
    "next-auth": "^4.24.11",
    "otpauth": "^9.5.1",
    "playwright-core": "^1.61.1",
    "prisma": "^6.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "resend": "^6.12.4",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^17.0.0",
    "tailwind-merge": "^2.5.4",
    "ts-node": "^10.9.2",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "@types/estree": "file:/tmp/types-estree.tgz",
    "@nolyfill/is-core-module": "file:/tmp/nolyfill-is-core-module.tgz"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
